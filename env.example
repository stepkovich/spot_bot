# ============================================================
# SPOT BOT — Настройки (env.example)
# ============================================================
# Скопируй этот файл в "env" или ".env" и заполни свои значения.
# Бот ищет сначала файл "env", потом ".env" — в текущей папке и
# в папке скрипта.
#
# У всех параметров есть разумные значения по умолчанию —
# обязательно заполнять только API-ключи.
# ============================================================

# --- Ключи API Binance ---
# DEMO:     ключи с demo.binance.com (виртуальные деньги на реальном аккаунте)
BINANCE_API_KEY=/////
BINANCE_API_SECRET=/////

# MAINNET:  твои настоящие ключи Binance (РЕАЛЬНЫЕ ДЕНЬГИ!)
#BINANCE_API_KEY=/////
#BINANCE_API_SECRET=/////


# --- Режим работы ---
# demo    = demo-api.binance.com       (виртуальные деньги, реальный аккаунт)
# testnet = testnet.binance.vision     (тестнет, отдельная регистрация)
# mainnet = api.binance.com            (РЕАЛЬНЫЕ ДЕНЬГИ — будь осторожен!)
MODE=mainnet

# --- Торговые пары ---
# Через запятую, без пробелов. Названия должны точно совпадать с Binance.
# Примеры: DOGEUSDT, SUIUSDT, 1000PEPEUSDT, BTCUSDT
# Важно: выбирай монеты с боковиком (рэнджем), не трендовые.
# DOGE, SHIB, XRP — хорошо. BTC, ETH в тренде — хуже.
SYMBOLS=DOGEUSDT

# --- Параметры сетки ---
# Шаг между уровнями сетки в процентах от цены.
# Со скидкой BNB: комиссия = 0.075% за сделку = 0.15% за цикл (купил + продал)
# Шаг 0.2% -> ~0.05% чистой прибыли за цикл купил->продал
# Шаг 0.3% -> ~0.15% чистой прибыли за цикл (более консервативно)
# ВНИМАНИЕ: шаг < 0.15% = торговля в убыток (комиссия съедает прибыль)!
GRID_STEP_PCT=0.3

# Количество уровней сетки на каждую сторону (ПОКУПКИ + ПРОДАЖИ)
# Всего ордеров = GRID_LEVELS * 2 * количество_пар
# 10 уровней × 0.2% шаг = покрывает 2% движения в одну сторону
GRID_LEVELS=30

# Размер одного ордера в USDT (базовый, до применения асимметрии)
GRID_ORDER_SIZE_USDT=1

# Минимальный размер ордера в USDT
# Асимметрия может уменьшить размер ордера — MIN не даёт ему стать
# слишком маленьким (Binance отклоняет ордера меньше min notional)
# Важно: для BTCUSDT min notional = 5 USDT, для DOGEUSDT = 1 USDT
GRID_MIN_ORDER_USDT=1

# Максимальный размер ордера в USDT
# Предохранитель: если BASE слишком большой или добавлен мартингейл —
# MAX ограничивает максимальный размер одного ордера
GRID_MAX_ORDER_USDT=50

# --- Распределение баланса ---
# Какую долю от общего баланса использовать для торговли (0.5 = 50%)
BALANCE_RATIO=1

# --- Асимметрия (автобалансировка через размер ордеров) ---
# Если доля USDT упала ниже ASYMMETRY_LOW -> уменьшаем размер ордеров ПОКУПКИ
# Если доля USDT поднялась выше ASYMMETRY_HIGH -> уменьшаем размер ордеров ПРОДАЖИ
# Это не даёт одной стороне исчерпать средства
ASYMMETRY_ENABLED=true
ASYMMETRY_LOW=0.3
ASYMMETRY_HIGH=0.7

# --- Инвентарный лимит (защита от полного исчерпания капитала) ---
# Сколько ПОДРЯД fills на одной стороне допустимо, прежде чем
# приостановить выставление ордеров на эту сторону.
# Пример: INVENTORY_LIMIT=5
#   5 BUY fills подряд -> BUY приостанавливается (не выставляем новые)
#   Ждём пока не придёт SELL fill -> BUY возобновляется
# 0 = отключено (нет ограничения — можно потратить весь USDT в один тренд)
# Рекомендуется: 5-8 для безопасной торговли, 0 для агрессивной
INVENTORY_LIMIT=0

# --- Интервалы (в секундах) ---
# Как часто опрашивать заполнение ордеров через REST
# (запасной вариант, основной — WebSocket)
FILL_POLL_INTERVAL=2

# Как часто обновлять баланс аккаунта
BALANCE_POLL_INTERVAL=30

# Задержка перед переподключением WebSocket при обрыве
WS_RECONNECT_DELAY=5

# --- Rate limiter (защита от бана Binance) ---
# Максимум order-операций (place/cancel) в секунду.
# Binance лимит: 10 orders/sec. Мы ставим 8 с запасом 2/sec.
# НЕ СТАВЬ > 10 — получите автоматический бан!
# При 30 уровнях сетки: 30 ордеров / 8 в сек = ~3.75 сек на сторону
# Меньшее значение = безопаснее но медленнее. Большее = быстрее но рискованнее.
ORDER_RATE_LIMIT=8

# --- Логирование ---
# Уровень логов: DEBUG (всё подробно), INFO (нормально), WARNING (мало), ERROR (только ошибки)
# DEBUG полезен для отладки — показывает каждый ордер и обработку заполнений
LOG_LEVEL=INFO

# Интервал вывода статуса здоровья бота (в секундах)
HEALTH_INTERVAL=60
